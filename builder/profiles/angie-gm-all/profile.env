PACKAGE_NAME=angie-gm-all
PACKAGE_FLAVOR=all
ENABLE_NTLS=true
ENABLE_HTTP3=true
ENABLE_STREAM=true
ENABLE_COMPAT=true
WITH_DEBUG=false
WITH_PCRE2=auto
WITH_ZLIB=bundled
WITH_TONGSUO=bundled
WITH_LIBATOMIC=auto
PACKAGE_FORMATS=deb,rpm
TARGET_ARCHES=x86_64,aarch64
SERVICE_NAME=angie
INSTALL_PREFIX=/opt/angie
CONF_PREFIX=/etc/angie
STATE_DIR=/var/lib/angie
CACHE_DIR=/var/cache/angie
LOG_DIR=/var/log/angie
RUN_DIR=/run/angie
CONFLICTS=angie,angie-gm-basic
REPLACES=angie
PROVIDES=
